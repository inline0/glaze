{
  "name": "glaze-monorepo",
  "private": true,
  "packageManager": "bun@1.2.22",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --cwd packages/core dev",
    "build": "bun run --cwd packages/core build",
    "test": "bun run --cwd packages/core test",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "typecheck": "tsc --noEmit -p packages/core/tsconfig.json"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "typescript": "^5.9.3"
  }
}
